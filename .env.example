# Local environment configuration for smart-code-reviewer.
# This file is git-ignored — put real secrets here. See .env.example for docs.

# ── LLM / OpenRouter ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=google/gemini-2.5-flash
LLM_REASONING_EFFORT=

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_HTTP_TIMEOUT=30
